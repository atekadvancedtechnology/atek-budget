generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum PeriodStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ExpenseStatus {
  PENDING
  OK
  EXCEEDED
}

enum DebtStatus {
  ACTIVE
  PAID
  CANCELLED
}

enum DebtStrategy {
  AVALANCHE
  SNOWBALL
  CUSTOM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum IncomeAmountType {
  FIXED
  VARIABLE
  ESTIMATED
}

enum IncomeFrequency {
  ONE_TIME
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  IRREGULAR
  CUSTOM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  invitationsSent Invitation[]      @relation("InvitationsSent")
  auditLogs       AuditLog[]

  incomesCreated             Income[]             @relation("IncomeCreatedBy")
  incomesUpdated             Income[]             @relation("IncomeUpdatedBy")
  incomeReceiptsCreated      IncomeReceipt[]      @relation("IncomeReceiptCreatedBy")
  expensesCreated            Expense[]            @relation("ExpenseCreatedBy")
  expensesUpdated            Expense[]            @relation("ExpenseUpdatedBy")
  expensePaymentsCreated     ExpensePayment[]     @relation("ExpensePaymentCreatedBy")
  debtsCreated               Debt[]               @relation("DebtCreatedBy")
  debtsUpdated               Debt[]               @relation("DebtUpdatedBy")
  savingGoalsCreated         SavingGoal[]         @relation("SavingGoalCreatedBy")
  savingGoalsUpdated         SavingGoal[]         @relation("SavingGoalUpdatedBy")
  savingContributionsCreated SavingContribution[] @relation("SavingContributionCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id      String @id @default(cuid())
  name    String
  ownerId String

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     WorkspaceMember[]
  budgets     Budget[]
  invitations Invitation[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  responsibleIncomes         Income[]         @relation("IncomeResponsibleMember")
  responsibleIncomeReceipts  IncomeReceipt[]  @relation("IncomeReceiptResponsibleMember")
  responsibleExpenses        Expense[]        @relation("ExpenseResponsibleMember")
  responsibleExpensePayments ExpensePayment[] @relation("ExpensePaymentResponsibleMember")
  responsibleDebts           Debt[]           @relation("DebtResponsibleMember")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Budget {
  id                   String  @id @default(cuid())
  workspaceId          String
  name                 String
  currency             String  @default("RD$")
  startDayOfMonth      Int     @default(1)
  monthlySavingTarget  Decimal @default(0) @db.Decimal(12, 2)
  savingTargetPercent  Decimal @default(10) @db.Decimal(5, 2)
  emergencyFundTarget  Decimal @default(0) @db.Decimal(12, 2)
  emergencyFundCurrent Decimal @default(0) @db.Decimal(12, 2)

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  periods      BudgetPeriod[]
  categories   ExpenseCategory[]
  bankAccounts BankAccount[]
  currencies   Currency[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Currency {
  id               String  @id @default(cuid())
  budgetId         String
  code             String
  name             String
  symbol           String
  defaultRateToDop Decimal @default(1) @db.Decimal(12, 4)
  isBase           Boolean @default(false)
  isActive         Boolean @default(true)

  budget          Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  incomes         Income[]         @relation("IncomeCurrency")
  incomeReceipts  IncomeReceipt[]  @relation("IncomeReceiptCurrency")
  expenses        Expense[]        @relation("ExpenseCurrency")
  expensePayments ExpensePayment[] @relation("ExpensePaymentCurrency")
  debts           Debt[]           @relation("DebtCurrency")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, code])
  @@index([budgetId, isActive])
}

model BudgetPeriod {
  id       String       @id @default(cuid())
  budgetId String
  year     Int
  month    Int
  status   PeriodStatus @default(DRAFT)

  budget          Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  incomes         Income[]
  incomeReceipts  IncomeReceipt[]
  expenses        Expense[]
  expensePayments ExpensePayment[]
  debts           Debt[]
  savingGoals     SavingGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, year, month])
  @@index([budgetId, status])
}

model Income {
  id                  String           @id @default(cuid())
  budgetPeriodId      String
  responsibleName     String
  responsibleMemberId String?
  currencyId          String?
  currencyCode        String           @default("DOP")
  currencySymbol      String           @default("RD$")
  amountOriginal      Decimal          @default(0) @db.Decimal(12, 2)
  exchangeRateToDop   Decimal          @default(1) @db.Decimal(12, 4)
  amountDop           Decimal          @default(0) @db.Decimal(12, 2)
  amount              Decimal          @default(0) @db.Decimal(12, 2)
  amountType          IncomeAmountType @default(FIXED)
  frequency           IncomeFrequency  @default(MONTHLY)
  startDate           DateTime         @default(now())
  endDate             DateTime?
  customRule          String?
  expectedPaymentDays Int[]            @default([])
  amountQ1            Decimal          @db.Decimal(12, 2)
  amountQ2            Decimal          @db.Decimal(12, 2)
  source              String
  notes               String?
  isActive            Boolean          @default(true)
  createdById         String?
  updatedById         String?

  budgetPeriod      BudgetPeriod     @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  responsibleMember WorkspaceMember? @relation("IncomeResponsibleMember", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  currency          Currency?        @relation("IncomeCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  receipts          IncomeReceipt[]
  createdBy         User?            @relation("IncomeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?            @relation("IncomeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetPeriodId, responsibleName, source])
  @@index([responsibleMemberId])
  @@index([currencyId])
  @@index([createdById])
}

model IncomeReceipt {
  id                  String   @id @default(cuid())
  budgetPeriodId      String
  incomeId            String?
  responsibleName     String
  responsibleMemberId String?
  currencyId          String?
  currencyCode        String   @default("DOP")
  currencySymbol      String   @default("RD$")
  amountOriginal      Decimal  @default(0) @db.Decimal(12, 2)
  exchangeRateToDop   Decimal  @default(1) @db.Decimal(12, 4)
  amountDop           Decimal  @default(0) @db.Decimal(12, 2)
  source              String
  amount              Decimal  @db.Decimal(12, 2)
  receivedDate        DateTime
  notes               String?
  createdById         String?

  budgetPeriod      BudgetPeriod     @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  income            Income?          @relation(fields: [incomeId], references: [id], onDelete: SetNull)
  responsibleMember WorkspaceMember? @relation("IncomeReceiptResponsibleMember", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  currency          Currency?        @relation("IncomeReceiptCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("IncomeReceiptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([budgetPeriodId, receivedDate])
  @@index([incomeId])
  @@index([responsibleMemberId])
  @@index([currencyId])
  @@index([createdById])
}

model ExpenseCategory {
  id                    String  @id @default(cuid())
  budgetId              String
  name                  String
  icon                  String?
  recommendedMaxPercent Decimal @db.Decimal(5, 2)
  isDefault             Boolean @default(false)

  budget          Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenses        Expense[]
  expensePayments ExpensePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, name])
}

model BankAccount {
  id          String  @id @default(cuid())
  budgetId    String
  name        String
  institution String
  type        String
  notes       String?

  budget          Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenses        Expense[]
  expensePayments ExpensePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, name])
}

model Expense {
  id                     String           @id @default(cuid())
  budgetPeriodId         String
  name                   String
  responsibleName        String
  responsibleMemberId    String?
  categoryId             String
  currencyId             String?
  currencyCode           String           @default("DOP")
  currencySymbol         String           @default("RD$")
  amountType             IncomeAmountType @default(FIXED)
  amountBudgetedOriginal Decimal          @default(0) @db.Decimal(12, 2)
  amountQ1Original       Decimal          @default(0) @db.Decimal(12, 2)
  amountQ2Original       Decimal          @default(0) @db.Decimal(12, 2)
  exchangeRateToDop      Decimal          @default(1) @db.Decimal(12, 4)
  amountBudgetedDop      Decimal          @default(0) @db.Decimal(12, 2)
  amountBudgetedMonthly  Decimal          @db.Decimal(12, 2)
  amountQ1               Decimal          @db.Decimal(12, 2)
  amountQ2               Decimal          @db.Decimal(12, 2)
  bankAccountId          String?
  actualAmount           Decimal?         @db.Decimal(12, 2)
  difference             Decimal          @default(0) @db.Decimal(12, 2)
  status                 ExpenseStatus    @default(PENDING)
  expenseDate            DateTime?
  isRecurring            Boolean          @default(true)
  isActive               Boolean          @default(true)
  notes                  String?
  createdById            String?
  updatedById            String?

  budgetPeriod      BudgetPeriod     @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  responsibleMember WorkspaceMember? @relation("ExpenseResponsibleMember", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  category          ExpenseCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  currency          Currency?        @relation("ExpenseCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  bankAccount       BankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  payments          ExpensePayment[]
  createdBy         User?            @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?            @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetPeriodId, name])
  @@index([responsibleMemberId])
  @@index([categoryId])
  @@index([currencyId])
  @@index([bankAccountId])
}

model ExpensePayment {
  id                  String   @id @default(cuid())
  budgetPeriodId      String
  expenseId           String?
  name                String
  responsibleName     String
  responsibleMemberId String?
  categoryId          String
  bankAccountId       String?
  currencyId          String?
  currencyCode        String   @default("DOP")
  currencySymbol      String   @default("RD$")
  amountOriginal      Decimal  @default(0) @db.Decimal(12, 2)
  exchangeRateToDop   Decimal  @default(1) @db.Decimal(12, 4)
  amountDop           Decimal  @default(0) @db.Decimal(12, 2)
  amount              Decimal  @db.Decimal(12, 2)
  paidDate            DateTime
  notes               String?
  createdById         String?

  budgetPeriod      BudgetPeriod     @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  expense           Expense?         @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  responsibleMember WorkspaceMember? @relation("ExpensePaymentResponsibleMember", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  category          ExpenseCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bankAccount       BankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  currency          Currency?        @relation("ExpensePaymentCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("ExpensePaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([budgetPeriodId, paidDate])
  @@index([expenseId])
  @@index([responsibleMemberId])
  @@index([categoryId])
  @@index([bankAccountId])
  @@index([currencyId])
  @@index([createdById])
}

model Debt {
  id                     String       @id @default(cuid())
  budgetPeriodId         String
  name                   String
  entity                 String
  responsibleName        String
  responsibleMemberId    String?
  currencyId             String?
  currencyCode           String       @default("DOP")
  currencySymbol         String       @default("RD$")
  pendingBalanceOriginal Decimal      @default(0) @db.Decimal(12, 2)
  monthlyPaymentOriginal Decimal      @default(0) @db.Decimal(12, 2)
  exchangeRateToDop      Decimal      @default(1) @db.Decimal(12, 4)
  pendingBalanceDop      Decimal      @default(0) @db.Decimal(12, 2)
  monthlyPaymentDop      Decimal      @default(0) @db.Decimal(12, 2)
  pendingBalance         Decimal      @db.Decimal(12, 2)
  monthlyPayment         Decimal      @db.Decimal(12, 2)
  annualInterestRate     Decimal      @db.Decimal(6, 2)
  remainingMonths        Int
  estimatedTotalInterest Decimal      @db.Decimal(12, 2)
  strategy               DebtStrategy @default(CUSTOM)
  startDate              DateTime?
  estimatedCloseDate     DateTime?
  status                 DebtStatus   @default(ACTIVE)
  notes                  String?
  createdById            String?
  updatedById            String?

  budgetPeriod      BudgetPeriod     @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  responsibleMember WorkspaceMember? @relation("DebtResponsibleMember", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  currency          Currency?        @relation("DebtCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("DebtCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?            @relation("DebtUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetPeriodId, name, entity])
  @@index([responsibleMemberId])
  @@index([currencyId])
}

model SavingGoal {
  id                   String  @id @default(cuid())
  budgetPeriodId       String
  name                 String
  monthlyTarget        Decimal @db.Decimal(12, 2)
  contributedThisMonth Decimal @db.Decimal(12, 2)
  accumulatedBalance   Decimal @db.Decimal(12, 2)
  institution          String
  priority             Int
  notes                String?
  createdById          String?
  updatedById          String?

  budgetPeriod  BudgetPeriod         @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  contributions SavingContribution[]
  createdBy     User?                @relation("SavingGoalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                @relation("SavingGoalUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetPeriodId, name])
}

model SavingContribution {
  id               String   @id @default(cuid())
  savingGoalId     String
  amount           Decimal  @db.Decimal(12, 2)
  contributionDate DateTime
  notes            String?
  createdById      String?

  savingGoal SavingGoal @relation(fields: [savingGoalId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation("SavingContributionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([savingGoalId, contributionDate])
}

model Invitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, email])
}

model AuditLog {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String?
  entityType  String
  entityId    String
  action      String
  oldValue    Json?
  newValue    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId])
}
